		const deckEntries = Object.entries(TarotDeck);
		const positionLabels = ["Pasado", "Presente", "Futuro"];
		let mode = "yesno";
		let selectedKeys = [];
		let cardStates = new Map();
		let locked = false;

		function shuffle(array) {
			const clone = [...array];
			for (let index = clone.length - 1; index > 0; index -= 1) {
				const swapIndex = Math.floor(Math.random() * (index + 1));
				[clone[index], clone[swapIndex]] = [clone[swapIndex], clone[index]];
			}
			return clone;
		}

		function getRequiredSelections() {
			return mode === "yesno" ? 1 : 3;
		}

		function getModeText() {
			if (mode === "yesno") {
				return "En Sí o No eliges una sola carta y recibes una respuesta concreta para entender qué energía acompaña hoy tu pregunta.";
			}

			return "En la tirada de 3 cartas observas pasado, presente y futuro para entender el proceso completo y ver hacia dónde se está moviendo tu energía.";
		}

		function updateSelectionHint() {
			selectionHint.innerHTML = `Seleccionadas: <strong>${selectedKeys.length} / ${getRequiredSelections()}</strong>`;
			revealButton.disabled = selectedKeys.length !== getRequiredSelections() || locked;
		}

		function setStatus(message) {
			statusText.textContent = message;
		}

		function getCardState(key) {
			return cardStates.get(key);
		}

		function createCardElement([key, data], index, total) {
			const card = document.createElement("button");
			card.type = "button";
			card.className = "flip-card";
			card.dataset.key = key;
			card.setAttribute("aria-label", `Seleccionar ${data.nombre}`);
			card.style.zIndex = String(index + 1);
			card.innerHTML = `
				<span class="sr-only">${data.nombre}</span>
				<div class="flip-card-inner">
					<div class="flip-card-back">
						<div class="card-back-emblem">✦</div>
					</div>
					<div class="flip-card-front">
						<div>
							<div class="card-label">Arcano Mayor</div>
							<div class="card-symbol">${data.simbolo}</div>
							<div class="card-name">${data.nombre}</div>
							<div class="card-verdict">${data.veredicto}</div>
							<p class="card-short">${data.mensaje_corto}</p>
						</div>
						<div class="card-position"></div>
					</div>
				</div>
			`;

			const spreadOffset = index - (total - 1) / 2;
			const translateX = spreadOffset * 34;
			const rotate = spreadOffset * 2.3;
			const translateY = Math.abs(spreadOffset) * 3;

			requestAnimationFrame(() => {
				setTimeout(() => {
					card.classList.add("is-visible");
					card.style.transform = `translateX(${translateX}px) translateY(${translateY}px) rotate(${rotate}deg)`;
				}, index * 45);
			});

			card.addEventListener("click", () => handleCardSelection(key));
			return card;
		}

		function desplegarCartas() {
			board.innerHTML = "";
			cardStates = new Map();
			selectedKeys = [];
			locked = false;
			resultShell.classList.remove("is-visible");
			readingGrid.innerHTML = "";
			const shuffledDeck = shuffle(deckEntries);

			shuffledDeck.forEach((entry, index) => {
				const key = entry[0];
				const element = createCardElement(entry, index, shuffledDeck.length);
				board.appendChild(element);
				cardStates.set(key, {
					key,
					data: entry[1],
					element,
					orientation: "upright",
					finalData: null,
					position: ""
				});
			});

			setStatus("Elegí la carta que más te llama y deja que la lectura acomode el mensaje.");
			modeMeta.textContent = getModeText();
			updateSelectionHint();
		}

		function handleCardSelection(key) {
			if (locked) {
				return;
			}

			const required = getRequiredSelections();
			const state = getCardState(key);
			if (!state) {
				return;
			}

			const alreadySelected = selectedKeys.includes(key);
			if (alreadySelected) {
				selectedKeys = selectedKeys.filter((selectedKey) => selectedKey !== key);
				state.element.classList.remove("is-selected");
				state.element.querySelector(".card-position").textContent = "";
			} else {
				if (selectedKeys.length >= required) {
					setStatus(`Ya elegiste ${required} carta${required > 1 ? "s" : ""}. Puedes ver tu lectura o cambiar tu selección.`);
					return;
				}

				selectedKeys.push(key);
				state.element.classList.add("is-selected");
			}

			selectedKeys.forEach((selectedKey, index) => {
				const selectedState = getCardState(selectedKey);
				if (selectedState) {
					const label = mode === "three" ? positionLabels[index] : "Seleccionada";
					selectedState.position = label;
					selectedState.element.querySelector(".card-position").textContent = label;
				}
			});

			cardStates.forEach((cardState) => {
				if (!selectedKeys.includes(cardState.key)) {
					cardState.position = "";
					cardState.element.querySelector(".card-position").textContent = "";
				}
			});

			if (selectedKeys.length === required) {
				setStatus("Tu selección ya está lista. Cuando quieras, abre la lectura y mira qué se revela.");
			} else {
				setStatus(`Llevas ${selectedKeys.length} de ${required}. Sigue eligiendo y deja que la energía termine de ordenarse.`);
			}

			updateSelectionHint();
		}

		function applyInversion(cardData) {
			const isReversed = Math.random() < 0.3;
			const finalEnergy = isReversed ? cardData.energia * -1 : cardData.energia;
			let finalVerdict = cardData.veredicto;
			if (isReversed) {
				if (cardData.energia > 0) {
					finalVerdict = "NO / BLOQUEADO";
				} else if (cardData.energia < 0) {
					finalVerdict = "QUIZÁS / SE LIBERA";
				} else {
					finalVerdict = "INCIERTO";
				}
			}

			return {
				...cardData,
				energia: finalEnergy,
				veredicto: finalVerdict,
				invertida: isReversed,
				interpretacion: isReversed
					? `La carta sale invertida, indicando bloqueos o retrasos en ${cardData.interpretacion.charAt(0).toLowerCase()}${cardData.interpretacion.slice(1)}`
					: cardData.interpretacion
			};
		}

		function centerSelectedCards() {
			const spacing = mode === "yesno" ? 0 : 196;
			selectedKeys.forEach((key, index) => {
				const state = getCardState(key);
				const offset = index - (selectedKeys.length - 1) / 2;
				const translateX = offset * spacing;
				const translateY = 0;
				state.element.classList.add("is-center");
				state.element.style.transform = `translateX(${translateX}px) translateY(${translateY}px) rotate(0deg) scale(1.05)`;
			});
		}

		function fadeOtherCards() {
			cardStates.forEach((state) => {
				if (!selectedKeys.includes(state.key)) {
					state.element.classList.add("is-dimmed");
				}
			});
		}

		function flipSelectedCards() {
			selectedKeys.forEach((key, index) => {
				const state = getCardState(key);
				const finalData = applyInversion(state.data);
				state.finalData = finalData;
				state.orientation = finalData.invertida ? "invertida" : "upright";
				state.element.classList.add("is-flipped", "is-aura");
				state.element.style.setProperty("--aura-color", finalData.color_aura);
				state.element.querySelector(".card-verdict").textContent = finalData.veredicto;
				state.element.querySelector(".card-short").textContent = finalData.mensaje_corto;
				if (mode === "three") {
					state.element.querySelector(".card-position").textContent = positionLabels[index];
				}
			});
		}

		function calcularResultadoTirada(cartasSeleccionadas) {
			let scoreTotal = 0;
			cartasSeleccionadas.forEach((cardData) => {
				scoreTotal += cardData.energia;
			});

			if (scoreTotal >= 2) {
				return "SÍ ROTUNDO (Energía Muy Positiva)";
			}
			if (scoreTotal > 0) {
				return "SÍ (Con reservas)";
			}
			if (scoreTotal === 0) {
				return "INCIERTO (Energía Neutra)";
			}
			if (scoreTotal > -2) {
				return "NO (Con dificultades)";
			}

			return "NO ROTUNDO (Mucha resistencia)";
		}

		function renderReadingResult() {
			const resolvedStates = selectedKeys.map((key) => getCardState(key));
			const resolvedCards = resolvedStates.map((state) => state.finalData);
			resultShell.classList.add("is-visible");
			readingGrid.innerHTML = "";

			if (mode === "yesno") {
				const [state] = resolvedStates;
				resultTitle.textContent = state.finalData.nombre;
				resultVerdict.textContent = state.finalData.veredicto;
				resultVerdict.style.color = state.finalData.color_aura;
				resultSummary.textContent = state.finalData.interpretacion;
				openModal(state);
				return;
			}

			const score = resolvedCards.reduce((total, card) => total + card.energia, 0);
			const finalVerdict = calcularResultadoTirada(resolvedCards);
				resultTitle.textContent = "Lectura evolutiva de tu tirada";
			resultVerdict.textContent = finalVerdict;
			resultVerdict.style.color = score >= 1 ? "#d4af37" : score <= -1 ? "#ff7272" : "#a8d8ff";
				resultSummary.textContent = "Esta lectura une pasado, presente y futuro para mostrarte qué se está moviendo, dónde está el aprendizaje y hacia qué dirección conviene ir ahora.";

			resolvedStates.forEach((state, index) => {
				const item = document.createElement("article");
				item.className = "reading-card-summary";
				item.innerHTML = `
					<strong>${positionLabels[index]}: ${state.finalData.nombre}</strong>
					<p class="reading-meta">${state.finalData.interpretacion}</p>
					<p class="reading-meta"><strong>Consejo:</strong> ${state.finalData.consejo}</p>
				`;
				readingGrid.appendChild(item);
			});

			openModal({
				finalData: {
					nombre: "Síntesis de la tirada",
					veredicto: finalVerdict,
					interpretacion: `Score energético total: ${score}. ${finalVerdict}.`,
					consejo: "No te quedes solo con una impresión rápida. Integra las tres posiciones y usa esta lectura para tomar decisiones con más claridad y coherencia.",
					color_aura: score >= 1 ? "var(--gold-electric)" : score <= -1 ? "var(--red-electric)" : "var(--cyan-electric)",
					invertida: false
				},
				position: "Tirada completa"
			});
		}

		function revealSelection() {
			if (selectedKeys.length !== getRequiredSelections() || locked) {
				return;
			}

			locked = true;
			revealButton.disabled = true;
			setStatus("Abriendo el mensaje que esta lectura tiene para vos...");
			fadeOtherCards();
			centerSelectedCards();

			setTimeout(() => {
				flipSelectedCards();
				setTimeout(() => {
					renderReadingResult();
					setStatus("La lectura ya está abierta. Si querés, puedes volver a mezclar el mazo y consultar otra vez.");
				}, 880);
			}, 420);
		}

		function openModal(state) {
			const { finalData } = state;
			modalTitle.textContent = finalData.nombre;
			modalVerdict.textContent = finalData.veredicto;
			modalVerdict.style.color = finalData.color_aura;
			modalInterpretation.textContent = finalData.interpretacion;
			modalAdvice.textContent = finalData.consejo;
			modalNote.textContent = state.position
				? `${state.position}${finalData.invertida ? " · Carta invertida" : " · Carta en posición natural"}`
				: finalData.invertida
					? "Carta invertida"
					: "Carta en posición natural";
			cardModal.classList.add("is-open");
			cardModal.setAttribute("aria-hidden", "false");
		}

		function closeModal() {
			cardModal.classList.remove("is-open");
			cardModal.setAttribute("aria-hidden", "true");
		}

		function setMode(nextMode) {
			mode = nextMode;
			modeButtons.forEach((button) => {
				const active = button.dataset.mode === nextMode;
				button.classList.toggle("is-active", active);
				button.setAttribute("aria-pressed", active ? "true" : "false");
			});
			desplegarCartas();
		}

		modeButtons.forEach((button) => {
			button.addEventListener("click", () => setMode(button.dataset.mode));
		});

		resetButton.addEventListener("click", desplegarCartas);
		revealButton.addEventListener("click", revealSelection);
		modalClose.addEventListener("click", closeModal);
		cardModal.addEventListener("click", (event) => {
			if (event.target === cardModal) {
				closeModal();
			}
		});

		document.addEventListener("keydown", (event) => {
			if (event.key === "Escape") {
				closeModal();
			}
		});

		window.addEventListener("pointermove", (event) => {
			const x = ((event.clientX / window.innerWidth) - 0.5) * 18;
			const y = ((event.clientY / window.innerHeight) - 0.5) * 18;
			document.body.style.setProperty("--parallax-x", `${x}px`);
			document.body.style.setProperty("--parallax-y", `${y}px`);
		});

		desplegarCartas();
	</script>
</body>
</html>
