<!DOCTYPE html>
<html lang="es">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<meta name="theme-color" content="#07070c">
	<meta name="description" content="Tarot evolutivo interactivo de Emuna con lectura Sí/No y tirada de 3 cartas en una experiencia mística y directa.">
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet">
	<title>Tarot Evolutivo | Emuna</title>
	<style>
		:root {
			--bg-main: radial-gradient(circle at 50% 18%, rgba(212, 175, 55, 0.08), transparent 16%), radial-gradient(circle at 20% 20%, rgba(160, 32, 240, 0.16), transparent 24%), radial-gradient(circle at 80% 22%, rgba(64, 224, 208, 0.12), transparent 20%), linear-gradient(180deg, #05000f 0%, #0b021d 42%, #16052f 100%);
			--card-back: linear-gradient(135deg, #16052f 0%, #0b021d 100%);
			--gold-electric: #d4af37;
			--gold-soft: #f9f295;
			--gold-glow: rgba(212, 175, 55, 0.4);
			--blue-electric: #40e0d0;
			--red-electric: #ff8db5;
			--violet-electric: #a020f0;
			--cyan-electric: #40e0d0;
			--glass-bg: rgba(20, 8, 44, 0.78);
			--glass-border: rgba(249, 242, 149, 0.16);
			--text-main: #f4ebff;
			--text-soft: #cab7e8;
			--panel-shadow: 0 24px 70px rgba(0, 0, 0, 0.42), 0 0 40px rgba(160, 32, 240, 0.16);
			--card-width: 158px;
			--card-height: 270px;
		}

		* {
			box-sizing: border-box;
		}

		html {
			color-scheme: dark;
		}

		body {
			margin: 0;
			min-height: 100vh;
			font-family: "Manrope", sans-serif;
			color: var(--text-main);
			background: var(--bg-main);
			overflow-x: hidden;
		}

		body::before,
		body::after {
			content: "";
			position: fixed;
			inset: 0;
			pointer-events: none;
			z-index: -2;
		}

		body::before {
			background:
				radial-gradient(circle at 20% 20%, rgba(64, 224, 208, 0.1), transparent 22%),
				radial-gradient(circle at 80% 15%, rgba(212, 175, 55, 0.12), transparent 18%),
				radial-gradient(circle at 50% 60%, rgba(160, 32, 240, 0.14), transparent 26%);
			transform: translate3d(var(--parallax-x, 0), var(--parallax-y, 0), 0);
			transition: transform 120ms linear;
		}

		body::after {
			background-image:
				radial-gradient(circle at 30% 10%, rgba(255, 255, 255, 0.08) 0 1px, transparent 1px),
				radial-gradient(circle at 70% 25%, rgba(255, 255, 255, 0.06) 0 1px, transparent 1px),
				radial-gradient(circle at 55% 70%, rgba(255, 255, 255, 0.04) 0 1px, transparent 1px);
			background-size: 220px 220px, 280px 280px, 320px 320px;
			opacity: 0.5;
			z-index: -1;
		}

		.page {
			width: min(1400px, calc(100% - 32px));
			margin: 0 auto;
			padding: 28px 0 48px;
		}

		.hero {
			display: grid;
			grid-template-columns: minmax(280px, 480px) minmax(320px, 1fr);
			gap: 28px;
			align-items: stretch;
			margin-bottom: 28px;
		}

		.glass-panel {
			position: relative;
			background: linear-gradient(180deg, rgba(20, 8, 44, 0.76), rgba(11, 2, 29, 0.9));
			border: 1px solid var(--glass-border);
			border-radius: 28px;
			box-shadow: var(--panel-shadow);
			backdrop-filter: blur(18px);
		}

		.hero-copy,
		.result-shell,
		.controls,
		.board-shell {
			padding: 28px;
		}

		.eyebrow {
			margin: 0 0 14px;
			font-size: 0.78rem;
			text-transform: uppercase;
			letter-spacing: 0.24em;
			color: var(--cyan-electric);
		}

		h1,
		h2,
		h3,
		.card-name,
		.modal-title {
			font-family: "Cinzel", serif;
		}

		h1 {
			margin: 0;
			font-size: clamp(2.4rem, 4vw, 4.8rem);
			line-height: 0.96;
			color: var(--gold-soft);
			text-wrap: balance;
		}

		.lead {
			margin: 18px 0 0;
			color: var(--text-soft);
			font-size: 1.05rem;
			line-height: 1.8;
			max-width: 40ch;
		}

		.benefits {
			display: flex;
			flex-wrap: wrap;
			gap: 10px;
			margin-top: 22px;
		}

		.benefit {
			padding: 10px 14px;
			border-radius: 999px;
			background: rgba(255, 255, 255, 0.05);
			border: 1px solid rgba(212, 175, 55, 0.18);
			color: var(--text-main);
			font-size: 0.92rem;
		}

		.controls {
			display: grid;
			align-content: center;
			gap: 18px;
		}

		.mode-switch {
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 10px;
		}

		.mode-button,
		.action-button,
		.ghost-button,
		.modal-close {
			appearance: none;
			border: 1px solid transparent;
			cursor: pointer;
			transition: transform 0.24s ease, box-shadow 0.24s ease, border-color 0.24s ease, background-color 0.24s ease;
			font: inherit;
		}

		.mode-button,
		.action-button,
		.ghost-button {
			min-height: 52px;
			border-radius: 999px;
			padding: 0.9rem 1.2rem;
			color: var(--text-main);
		}

		.mode-button {
			background: rgba(255, 255, 255, 0.05);
			border-color: rgba(255, 255, 255, 0.08);
		}

		.mode-button.is-active {
			background: linear-gradient(135deg, rgba(212, 175, 55, 0.22), rgba(64, 224, 208, 0.14));
			border-color: rgba(212, 175, 55, 0.48);
			box-shadow: 0 0 26px rgba(212, 175, 55, 0.16);
		}

		.action-button {
			background: linear-gradient(135deg, rgba(212, 175, 55, 0.24), rgba(160, 32, 240, 0.2));
			border-color: rgba(212, 175, 55, 0.5);
			box-shadow: 0 14px 34px rgba(0, 0, 0, 0.24), 0 0 24px rgba(212, 175, 55, 0.14);
			font-weight: 700;
			letter-spacing: 0.04em;
		}

		.ghost-button,
		.modal-close {
			background: rgba(255, 255, 255, 0.04);
			border-color: rgba(255, 255, 255, 0.08);
		}

		.mode-button:hover,
		.action-button:hover,
		.ghost-button:hover,
		.modal-close:hover,
		.mode-button:focus-visible,
		.action-button:focus-visible,
		.ghost-button:focus-visible,
		.modal-close:focus-visible {
			transform: translateY(-2px);
		}

		.mode-meta,
		.status,
		.result-summary,
		.reading-meta,
		.selected-hint {
			color: var(--text-soft);
			line-height: 1.7;
		}

		.status {
			min-height: 1.7em;
			font-style: italic;
		}

		.board-shell {
			min-height: 620px;
		}

		.board-header {
			display: flex;
			flex-wrap: wrap;
			justify-content: space-between;
			gap: 16px;
			margin-bottom: 22px;
		}

		.board-header h2 {
			margin: 0 0 6px;
			font-size: clamp(1.7rem, 2.2vw, 2.4rem);
			color: var(--gold-soft);
		}

		.selected-hint strong {
			color: var(--gold-electric);
		}

		.spread-board {
			position: relative;
			min-height: 470px;
			display: flex;
			align-items: center;
			justify-content: center;
			overflow: hidden;
			padding: 26px 12px 12px;
		}

		.flip-card {
			position: absolute;
			width: var(--card-width);
			height: var(--card-height);
			opacity: 0;
			transform: translateX(0) translateY(60px) rotate(0deg) scale(0.9);
			transition: transform 0.8s ease, opacity 0.55s ease, filter 0.35s ease;
			cursor: pointer;
			perspective: 1000px;
			will-change: transform;
		}

		.flip-card.is-visible {
			opacity: 1;
		}

		.flip-card-inner {
			position: relative;
			width: 100%;
			height: 100%;
			transition: transform 0.8s;
			transform-style: preserve-3d;
			box-shadow: 0 10px 26px rgba(0, 0, 0, 0.38);
			border-radius: 18px;
		}

		.flip-card.is-flipped .flip-card-inner {
			transform: rotateY(180deg);
		}

		.flip-card.is-selected {
			filter: drop-shadow(0 0 16px rgba(212, 175, 55, 0.5));
			z-index: 35;
		}

		.flip-card.is-dimmed {
			opacity: 0.08;
			pointer-events: none;
		}

		.flip-card.is-hidden {
			opacity: 0;
			pointer-events: none;
		}

		.flip-card.is-center {
			z-index: 40;
		}

		.flip-card.is-aura .flip-card-front {
			animation: auraPulse 1.8s ease-in-out infinite alternate;
		}

		.flip-card-front,
		.flip-card-back {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
			-webkit-backface-visibility: hidden;
			backface-visibility: hidden;
			border-radius: 18px;
			border: 2px solid var(--gold-electric);
			overflow: hidden;
		}

		.flip-card-back {
			background: var(--card-back);
		}

		.flip-card-back::before,
		.flip-card-back::after {
			content: "";
			position: absolute;
			inset: 0;
		}

		.flip-card-back::before {
			background:
				radial-gradient(circle at center, rgba(212, 175, 55, 0.18) 0 2px, transparent 2px),
				radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.08) 0 1px, transparent 1px),
				radial-gradient(circle at 70% 70%, rgba(255, 255, 255, 0.05) 0 1px, transparent 1px);
			background-size: 24px 24px, 110px 110px, 130px 130px;
			opacity: 0.85;
		}

		.flip-card-back::after {
			inset: 16px;
			border: 1px solid rgba(212, 175, 55, 0.35);
			border-radius: 12px;
		}

		.card-back-emblem {
			position: absolute;
			inset: 0;
			display: grid;
			place-items: center;
			color: rgba(255, 248, 216, 0.9);
			font-size: 2.8rem;
			text-shadow: 0 0 18px rgba(212, 175, 55, 0.24);
		}

		.flip-card-front {
			transform: rotateY(180deg);
			background: linear-gradient(180deg, rgba(250, 247, 238, 0.99), rgba(234, 225, 207, 0.99));
			color: #16131f;
			padding: 18px 16px;
			display: flex;
			flex-direction: column;
			justify-content: space-between;
		}

		.card-label {
			font-size: 0.72rem;
			letter-spacing: 0.16em;
			text-transform: uppercase;
			color: #766736;
		}

		.card-symbol {
			font-size: 2.4rem;
			text-align: center;
			margin-top: 8px;
		}

		.card-name {
			margin: 8px 0 0;
			font-size: 1.25rem;
			line-height: 1.1;
			text-align: center;
		}

		.card-verdict {
			margin-top: 12px;
			text-align: center;
			font-size: 1.08rem;
			font-weight: 800;
			letter-spacing: 0.04em;
		}

		.card-short {
			margin: 10px 0 0;
			font-size: 0.95rem;
			text-align: center;
			line-height: 1.45;
			color: #312c3e;
		}

		.card-position {
			align-self: center;
			margin-top: 8px;
			padding: 6px 10px;
			border-radius: 999px;
			background: rgba(22, 19, 31, 0.08);
			font-size: 0.72rem;
			font-weight: 700;
			letter-spacing: 0.12em;
			text-transform: uppercase;
		}

		.result-shell {
			margin-top: 24px;
			display: none;
		}

		.result-shell.is-visible {
			display: block;
			animation: fadeInUp 0.45s ease;
		}

		.result-shell h3 {
			margin: 0;
			font-size: 1.5rem;
			color: var(--gold-soft);
		}

		.result-verdict {
			margin: 12px 0 0;
			font-size: clamp(1.4rem, 3vw, 2rem);
			font-weight: 900;
			letter-spacing: 0.04em;
		}

		.reading-grid {
			display: grid;
			gap: 16px;
			margin-top: 18px;
		}

		.reading-card-summary {
			padding: 16px 18px;
			border-radius: 18px;
			background: rgba(255, 255, 255, 0.04);
			border: 1px solid rgba(255, 255, 255, 0.08);
		}

		.reading-card-summary strong {
			color: #fff0ba;
		}

		.modal {
			position: fixed;
			inset: 0;
			display: grid;
			place-items: center;
			padding: 18px;
			background: rgba(5, 5, 10, 0.82);
			backdrop-filter: blur(12px);
			opacity: 0;
			pointer-events: none;
			transition: opacity 0.28s ease;
			z-index: 80;
		}

		.modal.is-open {
			opacity: 1;
			pointer-events: auto;
		}

		.modal-card {
			width: min(100%, 620px);
			padding: 24px;
			border-radius: 26px;
			background: linear-gradient(180deg, rgba(20, 8, 44, 0.88), rgba(11, 2, 29, 0.94));
			border: 1px solid rgba(255, 255, 255, 0.12);
			box-shadow: var(--panel-shadow);
			transform: translateY(24px) scale(0.96);
			transition: transform 0.28s ease;
		}

		.modal.is-open .modal-card {
			transform: translateY(0) scale(1);
		}

		.modal-header {
			display: flex;
			justify-content: space-between;
			gap: 12px;
			align-items: start;
			margin-bottom: 14px;
		}

		.modal-title {
			margin: 0;
			font-size: 1.8rem;
			color: var(--gold-soft);
		}

		.modal-close {
			width: 42px;
			height: 42px;
			border-radius: 50%;
			color: var(--text-main);
		}

		.modal-verdict {
			font-size: 1.28rem;
			font-weight: 800;
			margin: 0 0 16px;
		}

		.modal-block {
			padding: 14px 16px;
			border-radius: 18px;
			background: rgba(255, 255, 255, 0.04);
			border: 1px solid rgba(255, 255, 255, 0.08);
			margin-top: 12px;
		}

		.modal-block strong {
			color: var(--gold-soft);
			display: block;
			margin-bottom: 6px;
		}

		.modal-note {
			margin-top: 12px;
			color: var(--text-soft);
			font-size: 0.94rem;
		}

		.sr-only {
			position: absolute;
			width: 1px;
			height: 1px;
			padding: 0;
			margin: -1px;
			overflow: hidden;
			clip: rect(0, 0, 0, 0);
			white-space: nowrap;
			border: 0;
		}

		@keyframes auraPulse {
			0% {
				box-shadow: 0 0 18px var(--aura-color, var(--gold-electric));
			}
			100% {
				box-shadow: 0 0 34px var(--aura-color, var(--gold-electric));
			}
		}

		@keyframes fadeInUp {
			from {
				opacity: 0;
				transform: translateY(12px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}

		@media (max-width: 1100px) {
			.hero {
				grid-template-columns: 1fr;
			}
		}

		@media (max-width: 780px) {
			.page {
				width: min(100%, calc(100% - 20px));
				padding-top: 18px;
			}

			.hero-copy,
			.result-shell,
			.controls,
			.board-shell,
			.modal-card {
				padding: 20px;
			}

			.spread-board {
				min-height: 420px;
			}

			.flip-card {
				width: 122px;
				height: 208px;
			}
		}

		@media (max-width: 560px) {
			.page {
				width: calc(100% - 12px);
			}

			.board-header {
				flex-direction: column;
			}

			.mode-switch {
				grid-template-columns: 1fr;
			}

			.flip-card {
				width: 98px;
				height: 166px;
			}

			.spread-board {
				min-height: 320px;
			}

			.card-name {
				font-size: 0.92rem;
			}

			.card-short,
			.card-position,
			.card-verdict,
			.card-label {
				font-size: 0.68rem;
			}

			.card-symbol {
				font-size: 1.6rem;
			}
		}
	</style>
</head>
<body>
	<main class="page">
		<section class="hero">
			<article class="glass-panel hero-copy">
				<p class="eyebrow">Tarot Evolutivo</p>
				<h1>Claridad directa para lo que hoy necesitás ver</h1>
				<p class="lead">No siempre hace falta una sesión extensa para sentir dirección. Este espacio está pensado para ayudarte a ordenar lo que intuís, escuchar la energía del momento y recibir una respuesta clara que te permita avanzar con más conciencia.</p>
				<div class="benefits">
					<span class="benefit">22 Arcanos Mayores</span>
					<span class="benefit">Lectura Sí o No</span>
					<span class="benefit">Tirada de 3 cartas</span>
					<span class="benefit">Mensaje claro y consejo directo</span>
				</div>
			</article>

			<aside class="glass-panel controls" aria-label="Controles de lectura">
				<div>
					<p class="eyebrow">Tu lectura</p>
					<div class="mode-switch" role="tablist" aria-label="Modo de tirada">
						<button class="mode-button is-active" id="modeYesNo" type="button" data-mode="yesno" aria-pressed="true">Sí / No</button>
						<button class="mode-button" id="modeThree" type="button" data-mode="three" aria-pressed="false">3 Cartas</button>
					</div>
				</div>
				<p class="mode-meta" id="modeMeta">En Sí o No eliges una sola carta y recibes una respuesta concreta para entender qué energía acompaña hoy tu pregunta.</p>
				<button class="action-button" id="resetButton" type="button">Volver a mezclar el mazo</button>
				<button class="ghost-button" id="revealButton" type="button" disabled>Ver mi resultado</button>
				<p class="status" id="statusText">Elegí la carta que más te llama y deja que la lectura acomode el mensaje.</p>
			</aside>
		</section>

		<section class="glass-panel board-shell">
			<div class="board-header">
				<div>
					<p class="eyebrow">Portal de lectura</p>
					<h2>Abanico de arcanos para tu consulta</h2>
				</div>
				<p class="selected-hint" id="selectionHint">Seleccionadas: <strong>0 / 1</strong></p>
			</div>

			<div class="spread-board" id="tablero" aria-live="polite"></div>

			<div class="result-shell glass-panel" id="resultShell">
				<p class="eyebrow">Tu mensaje</p>
				<h3 id="resultTitle">Energía disponible</h3>
				<p class="result-verdict" id="resultVerdict"></p>
				<p class="result-summary" id="resultSummary"></p>
				<div class="reading-grid" id="readingGrid"></div>
			</div>
		</section>
	</main>

	<div class="modal" id="cardModal" aria-hidden="true" role="dialog" aria-labelledby="modalTitle">
		<div class="modal-card">
			<div class="modal-header">
				<div>
					<p class="eyebrow">Mensaje del arcano</p>
					<h3 class="modal-title" id="modalTitle"></h3>
				</div>
				<button class="modal-close" id="modalClose" type="button" aria-label="Cerrar detalle">×</button>
			</div>
			<p class="modal-verdict" id="modalVerdict"></p>
			<div class="modal-block">
				<strong>Interpretación</strong>
				<span id="modalInterpretation"></span>
			</div>
			<div class="modal-block">
				<strong>Consejo</strong>
				<span id="modalAdvice"></span>
			</div>
			<p class="modal-note" id="modalNote"></p>
		</div>
	</div>

	<script>
		const TarotDeck = {
			el_loco: {
				id: "loco",
				nombre: "El Loco (0)",
				energia: 0,
				veredicto: "TAL VEZ",
				mensaje_corto: "Algo nuevo se mueve, pero todavía pide confianza y presencia.",
				interpretacion: "El Loco aparece cuando tu proceso necesita aire, apertura y una mirada menos rígida. La energía está viva, aunque no todo esté resuelto.",
				consejo: "Escucha el impulso, pero no te desconectes de la realidad. Avanza si de verdad sientes que ese paso te expande.",
				color_aura: "var(--cyan-electric)",
				simbolo: "✦"
			},
			el_mago: {
				id: "mago",
				nombre: "El Mago (I)",
				energia: 1,
				veredicto: "SÍ",
				mensaje_corto: "Tienes recursos, claridad y energía para mover esto.",
				interpretacion: "El Mago confirma que no te falta poder, sino decisión para usarlo. Hay herramientas, intención y capacidad para transformar lo que hoy consultas.",
				consejo: "Deja de postergarte. Lo que necesitas para empezar ya está en ti; ahora toca enfocarlo.",
				color_aura: "var(--gold-electric)",
				simbolo: "☀"
			},
			la_sacerdotisa: {
